# ============================================
# KisaanAI Health Chatbot — Environment Config
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ----- LLM API Keys -----
GENAI_API_KEY=your_google_generative_ai_key_here
GROQ_API_KEY=your_groq_api_key_here

# ----- Data Paths -----
# Relative to project root. Defaults shown.
DATA_DIR=./data
MODEL_DIR=./image_model

# ----- RAG Config -----
RAG_EMBED_MODEL=models/text-embedding-004
RAG_FAISS_INDEX=faiss_disease.index
RAG_FAISS_METADATA=faiss_metadata.json

# ----- Service URLs -----
RASA_ACTION_ENDPOINT=http://localhost:5055/webhook
REACT_APP_RASA_WEBHOOK=http://localhost:5005/webhooks/rest/webhook
REACT_APP_PLANT_API_URL=http://localhost:8001
